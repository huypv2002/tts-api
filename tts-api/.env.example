# Copy to .env on the Windows server
TTS_ADMIN_PASSWORD=change-me-strong-password
TTS_ADMIN_SECRET=change-me-long-random-secret-32chars
TTS_HOST=0.0.0.0
TTS_PORT=8787
# Optional public URL after Cloudflare Tunnel (e.g. https://tts.example.com)
TTS_PUBLIC_BASE_URL=
# Bootstrap first admin API key (optional; also created in DB on first boot)
TTS_BOOTSTRAP_API_KEY=
